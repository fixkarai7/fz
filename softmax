import numpy as np
import matplotlib.pyplot as plt
from sklearn.datasets import load_iris
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score

iris = load_iris()

X_train, X_test, y_train, y_test = train_test_split(
    iris.data, iris.target, test_size=0.2, random_state=42
)

X_train_bias = np.c_[np.ones((len(X_train), 1)), X_train]
X_test_bias = np.c_[np.ones((len(X_test), 1)), X_test]

def softmax(logits):
    exp_logits = np.exp(logits - np.max(logits, axis=1, keepdims=True))
    return exp_logits / np.sum(exp_logits, axis=1, keepdims=True)

n_inputs = X_train_bias.shape[1]
n_outputs = len(np.unique(y_train))
theta = np.random.randn(n_inputs, n_outputs)

eta = 0.1
n_epochs = 1000
max_epochs_without_improvement = 50

best_loss = np.inf
epochs_without_improvement = 0

train_losses = []
test_losses = []

for epoch in range(n_epochs):
    logits_train = X_train_bias.dot(theta)
    y_proba_train = softmax(logits_train)

    y_one_hot = np.eye(n_outputs)[y_train]

    loss_train = -np.mean(np.sum(y_one_hot * np.log(y_proba_train + 1e-8), axis=1))

    gradients = (1 / len(X_train_bias)) * X_train_bias.T.dot(y_proba_train - y_one_hot)
    theta -= eta * gradients

    logits_test = X_test_bias.dot(theta)
    y_proba_test = softmax(logits_test)

    y_test_one_hot = np.eye(n_outputs)[y_test]

    loss_test = -np.mean(np.sum(y_test_one_hot * np.log(y_proba_test + 1e-8), axis=1))

    train_losses.append(loss_train)
    test_losses.append(loss_test)

    if loss_test < best_loss:
        best_loss = loss_test
        epochs_without_improvement = 0
    else:
        epochs_without_improvement += 1

    if epochs_without_improvement > max_epochs_without_improvement:
        print("Early stopping at epoch:", epoch)
        break

logits_test = X_test_bias.dot(theta)
y_pred = np.argmax(softmax(logits_test), axis=1)

accuracy = accuracy_score(y_test, y_pred)
print("Accuracy:", accuracy)

plt.figure(figsize=(8, 6))
plt.plot(train_losses, label="Training Loss")
plt.plot(test_losses, label="Validation Loss")
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.title("Softmax Regression - Loss Curve")
plt.legend()
plt.show()
