import numpy as np

d = 0.85

A = np.array([
    [0, 1, 1],
    [0, 0, 1],
    [1, 0, 0]
], float)

N = A.shape[0]

M = (A.T / A.sum(axis=1)).T

r = np.ones(N)

for _ in range(30):
    r = (1 - d) / N + d * (M.T @ r)

print("PR(A) =", round(r[0], 4))
print("PR(B) =", round(r[1], 4))
print("PR(C) =", round(r[2], 4))
