import re

text = "Hello! My name is Fahad. I am learning NLP. It is very interesting."

sentences = re.split(r'[.!?]+', text)

print("Sentences:")
for s in sentences:
    if s:
        print(s.strip())

print("\nWord Tokens:")
for s in sentences:
    if s:
        words = s.split()
        print(words)
