import pandas as pd
import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers
import matplotlib.pyplot as plt

url = "https://raw.githubusercontent.com/mwaskom/seaborn-data/master/mpg.csv"
dataset = pd.read_csv(url)

dataset = dataset.rename(columns={
    "mpg": "MPG",
    "cylinders": "Cylinders",
    "displacement": "Displacement",
    "horsepower": "Horsepower",
    "weight": "Weight",
    "acceleration": "Acceleration",
    "model_year": "Model Year",
    "origin": "Origin"
})

dataset = dataset.dropna()

dataset = dataset.drop(columns=['name'])

dataset['USA'] = (dataset['Origin'] == 1)*1.0
dataset['Europe'] = (dataset['Origin'] == 2)*1.0
dataset['Japan'] = (dataset['Origin'] == 3)*1.0

dataset = dataset.drop(columns=['Origin'])

train_dataset = dataset.sample(frac=0.8, random_state=0)
test_dataset = dataset.drop(train_dataset.index)

train_labels = train_dataset.pop('MPG')
test_labels = test_dataset.pop('MPG')

train_stats = train_dataset.describe().transpose()

def norm(x):
    return (x - train_stats['mean']) / (train_stats['std'] + 1e-8)

normed_train_data = norm(train_dataset)
normed_test_data = norm(test_dataset)

model = keras.Sequential([
    layers.Dense(64, activation='relu', input_shape=[len(train_dataset.keys())]),
    layers.Dense(64, activation='relu'),
    layers.Dense(1)
])

model.compile(
    optimizer=tf.keras.optimizers.RMSprop(0.001),
    loss='mse',
    metrics=['mae', 'mse']
)

early_stop = keras.callbacks.EarlyStopping(monitor='val_loss', patience=20)

history = model.fit(
    normed_train_data,
    train_labels,
    epochs=500,
    validation_split=0.2,
    verbose=1,
    callbacks=[early_stop]
)

loss, mae, mse = model.evaluate(normed_test_data, test_labels, verbose=2)
print("\nFinal MAE:", mae)

test_predictions = model.predict(normed_test_data).flatten()

plt.scatter(test_labels, test_predictions)
plt.xlabel("True MPG")
plt.ylabel("Predicted MPG")
plt.title("True vs Predicted MPG")
plt.plot([0, 100], [0, 100], color='red')
plt.show()
