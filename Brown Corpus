import nltk
nltk.download('brown')
nltk.download('punkt')

from nltk.corpus import brown

print("File IDs:", brown.fileids()[:5])
print("\nCategories:", brown.categories())

print("\nRaw Text (first 200 chars):")
print(brown.raw()[:200])

print("\nWords:")
print(brown.words()[:20])

print("\nSentences:")
print(brown.sents()[:3])
