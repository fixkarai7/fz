from sumy.parsers.plaintext import PlaintextParser
from sumy.summarizers.lex_rank import LexRankSummarizer
from sumy.nlp.tokenizers import Tokenizer

text = "Artificial Intelligence is powerful. It learns from data. It helps humans. It improves systems."

parser = PlaintextParser.from_string(text, Tokenizer("english"))
summary = LexRankSummarizer()(parser.document, 2)

print("Extractive Summary:")
for s in summary:
    print(s)

def abstractive_summary(text):
    return "AI helps machines learn from data and improve systems."

print("\nAbstractive Summary:")
print(abstractive_summary(text))
